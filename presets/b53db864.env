# Preset aligned to commit b53db864dad270a8813c3deb49f96ba9f33d504a defaults (HFTEngine + bot risk).
# Load before starting the bot, e.g.: set -a && source hft_bot/presets/b53db864.env && set +a
#
# Newer pipeline features are turned off here so behavior is closer to that revision; results will
# still differ from a historical run (market, feeds, and code paths changed).

# --- HFTEngine numerics (legacy defaults) ---
HFT_NOISE_EDGE=4.5
HFT_BUY_EDGE=10.0
HFT_SELL_EDGE_ABS=10.0
HFT_COOLDOWN_SEC=0.0
HFT_MAX_POSITION_USD=90.0
HFT_DEFAULT_TRADE_USD=100.0
HFT_MIN_HOLD_SEC=2.5
HFT_REACTION_TIMEOUT_SEC=16.0
HFT_POLY_TP_MOVE=0.0030
HFT_POLY_SL_MOVE=0.0040
HFT_TARGET_PROFIT_USD=4.2
HFT_STOP_LOSS_USD=2.8
HFT_PNL_TP_PERCENT=0.042
HFT_PNL_SL_PERCENT=0.018
HFT_SPEED_FLOOR=0.15

HFT_RSI_ENTRY_YES_LOW=32.0
HFT_RSI_ENTRY_YES_HIGH=85.0
HFT_RSI_ENTRY_NO_LOW=15.0
HFT_RSI_ENTRY_NO_HIGH=68.0
HFT_RSI_EXIT_UPPER_BASE=85
HFT_RSI_EXIT_LOWER_BASE=15
HFT_RSI_RANGE_EXIT_MIN_PROFIT_USD=0.5
HFT_RSI_RANGE_EXIT_BAND_MARGIN=15.0
HFT_RSI_EXTREME_HIGH=85
HFT_RSI_EXTREME_LOW=15
HFT_RSI_BAND_VOL_K=0.08
HFT_RSI_RANGE_EXIT_PROFIT_FRAC=0.7
HFT_RSI_SLOPE_EXIT_ENABLED=0

HFT_ENTRY_CONFIRM_AGE_SEC=5.0
HFT_ENTRY_CONFIRM_AGE_STRONG_SEC=5.0
HFT_REVERSAL_CONFIRM_AGE_SEC=1.8
HFT_ENTRY_EXTREME_MIN_EDGE=15.0
HFT_ENTRY_EXTREME_PRICE_LOW=0.20
HFT_ENTRY_EXTREME_PRICE_HIGH=0.80
HFT_ENTRY_DEPTH_MULT=0.9
HFT_ENTRY_UP_SPEED_MIN=2.5
HFT_ENTRY_DOWN_SPEED_MAX=-2.5

HFT_DYNAMIC_RISK_PER_TICK_USD=2.0
HFT_DYNAMIC_AMOUNT_MIN_USD=40.0
HFT_DYNAMIC_AMOUNT_MAX_USD=90.0
HFT_DYNAMIC_MIN_EXEC_PRICE=0.01
HFT_DYNAMIC_FLOOR_NOTIONAL_USD=30.0
HFT_DYNAMIC_CHEAP_PRICE_BELOW=0.20
HFT_DYNAMIC_RICH_PRICE_ABOVE=0.70
HFT_DYNAMIC_AMOUNT_CHEAP_USD=45.0
HFT_DYNAMIC_AMOUNT_RICH_USD=80.0

HFT_REVERSAL_SPEED_FLOOR=0.20
HFT_BOOK_MOVE_ENTRY_MIN=0.0030
HFT_BOOK_MOVE_STOP_MAX=0.0005
HFT_BOOK_STALL_TICKS=999

# --- Disable newer entry guards (approximate legacy pipeline) ---
HFT_ENTRY_MAX_LATENCY_MS=0
HFT_ENTRY_RSI_SLOPE_FILTER_ENABLED=0
HFT_ENTRY_ZSCORE_TREND_ENABLED=0
HFT_ENTRY_CEX_IMBALANCE_ENABLED=0
HFT_ENTRY_ACCEL_ENABLED=0
HFT_ENTRY_MOMENTUM_ALT_ENABLED=0
HFT_TREND_FLIP_MIN_AGE_SEC=0
HFT_MAX_ENTRY_SPREAD=1.0
HFT_ENTRY_LIQUIDITY_MAX_SPREAD=0
HFT_LATENCY_HIGH_MS=999999
HFT_EXPIRY_EDGE_MULT=1.0
HFT_EXPIRY_TIGHT_SEC=0
HFT_ENTRY_LOW_SPEED_ABS=0
HFT_ENTRY_LOW_SPEED_EDGE_MULT=1.0

# --- Bot / risk (closer to pre-refactor bot.py defaults) ---
HFT_BYPASS_META_GATE=0
STATS_INTERVAL_SEC=60
LIVE_MAX_SPREAD=0.03
MAX_DRAWDOWN_PCT=0.12
MAX_POSITION_PCT=0.10
LIVE_MAX_DAILY_LOSS=-50
