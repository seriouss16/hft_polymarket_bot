+HFT_RSI_UP_ENTRY_MAX=50.0
+HFT_RSI_UP_SLOPE_MIN=0.0
+HFT_RSI_DOWN_ENTRY_MIN=50.0
+HFT_RSI_DOWN_SLOPE_MAX=0.0
+HFT_ENTRY_ZSCORE_TREND_ENABLED=1
+HFT_ENTRY_ZSCORE_STRICT_TICKS=2
+HFT_ENTRY_CEX_IMBALANCE_ENABLED=1
+HFT_CEX_IMBALANCE_UP_MIN=0.60
+HFT_CEX_IMBALANCE_DOWN_MAX=0.40
+
+# ---------------------------------------------------------------------
+# Regime filter and simulator controls.
+# Softer regime: shorter memory, easier "good" path, harder cooldown trigger, shorter pause.
+# ---------------------------------------------------------------------
+HFT_SIM_FEE_RATE=0.001
+HFT_RECENT_TRADES_FOR_REGIME=8
+HFT_GOOD_REGIME_WINRATE=0.42
+HFT_BAD_REGIME_WINRATE=0.35
+HFT_REGIME_COOLDOWN_SEC=60
