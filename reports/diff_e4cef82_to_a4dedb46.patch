+HFT_REGIME_BYPASS_SOFT_FLOW=1
+HFT_REGIME_SKIP_LOG_MIN_SEC=15
+HFT_SLOT_EXPIRY_INFO_LOG_MIN_SEC=8
+
+# ---------------------------------------------------------------------
+# Market phase: latency vs soft_flow on one engine (PhaseRouterStrategy).
+# Set HFT_ENABLE_PHASE_ROUTING=1 and HFT_ACTIVE_STRATEGY=phase_router to enable.
+# Soft_flow: directional UP/DOWN, bounded speed/edge, fresh feed; FLAT or bursts use latency.
+# ---------------------------------------------------------------------
+HFT_ENABLE_PHASE_ROUTING=1
+HFT_LOG_MARKET_PROFILE=0
+HFT_PHASE_SOFT_FLOW_ENABLE=1
