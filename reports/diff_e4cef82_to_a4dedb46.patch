+# ---------------------------------------------------------------------
+HFT_RSI_PRICE_LEN=128
+HFT_RSI_ENTRY_UP_LOW=20.0
+HFT_RSI_ENTRY_UP_HIGH=80.0
+HFT_RSI_ENTRY_DOWN_LOW=20.0
+HFT_RSI_ENTRY_DOWN_HIGH=80.0
+HFT_RSI_EXIT_UPPER_BASE=85
+HFT_RSI_EXIT_LOWER_BASE=15
+HFT_RSI_RANGE_EXIT_MIN_PROFIT_USD=0.3
+HFT_RSI_RANGE_EXIT_BAND_MARGIN=10.0
+HFT_RSI_EXTREME_HIGH=90
+HFT_RSI_EXTREME_LOW=10
+HFT_RSI_BAND_VOL_K=0.12
+HFT_RSI_RANGE_EXIT_PROFIT_FRAC=0.6
+HFT_RSI_RANGE_EXIT_MIN_HOLD_SEC=1.5
