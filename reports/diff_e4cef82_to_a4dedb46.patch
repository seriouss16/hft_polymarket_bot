+# Slightly tighter so BN-led spikes pull fast price sooner (USD residual after baseline).
+HFT_SMART_EXCESS_THRESHOLD_USD=4
+HFT_SMART_BINANCE_BLEND=0.7
+# Legacy path when baseline=0: blend full drift if |drift| > threshold (USD).
+HFT_SMART_DRIFT_THRESHOLD_USD=20
+STATS_INTERVAL_SEC=120
+PULSE_INTERVAL_SEC=0
+CLOB_BOOK_PULL_SEC=0
+LSTM_INFERENCE_SEC=0
+LIVE_ORDER_SIZE=10
+LIVE_MAX_SPREAD=1.0
