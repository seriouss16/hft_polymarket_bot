# =============================================================================
# SIM entry slippage (SIM / paper execution only — PnLTracker.log_trade BUY)
# =============================================================================
# Implemented in: hft_bot/core/executor.py (sim_entry_slippage_multiplier).
# LIVE fills are unchanged; this only worsens the simulated BUY price vs the book
# ask so paper PnL is closer to CLOB chase / partial fills.
#
# --- Estimate from your LIVE logs (placed limit vs filled avg) ---
# From hft_bot/:
#   uv run python scripts/analyze_live_entry_slippage.py reports/logs/<file>.log
# Whole folder (default glob *_live*.log):
#   uv run python scripts/analyze_live_entry_slippage.py reports/logs/
# All *.log recursively:
#   uv run python scripts/analyze_live_entry_slippage.py reports/logs/ --glob '*.log'
# Script path: hft_bot/scripts/analyze_live_entry_slippage.py
#
# Suggested env values in the script output: HFT_SIM_SLIPPAGE_EXTRA_FRACTION=...
# (mean over pairs; small samples / mixed logs can be noisy — prefer single good log.)
#
# --- Variables (optional companions documented in executor) ---
# HFT_SIM_SLIPPAGE_EXTRA_FRACTION — direct extra fraction on price after fee: exec *= (1 + value).
#   Example: 0.012 ≈ +1.2% worse than book. 0 = disabled.
# HFT_SIM_ENTRY_SLIPPAGE_SEC — if > 0 and direct fraction unset: linear model per_sec * sec (see executor).
# HFT_SIM_SLIPPAGE_EXTRA_FRACTION_PER_SEC — default 0.0005 in code.
# HFT_SIM_SLIPPAGE_EXTRA_CAP_FRACTION — default 0.08 in code.
#
# Load order (see bot_runtime.load_runtime_env): sim_slippage.env first (defaults),
# then runtime.env (overwrites keys it defines), then hft_bot/.env.
# =============================================================================

HFT_SIM_SLIPPAGE_EXTRA_FRACTION=0
