# Session profile DAY (weekday 06:00–23:00 UTC).
# Applied via core/session_profile.py — overrides process env for listed keys only.

# Speed
HFT_ENTRY_UP_SPEED_MIN=1.8
HFT_ENTRY_DOWN_SPEED_MAX=-1.8
HFT_SPEED_FLOOR=0.02

# Edge
HFT_BUY_EDGE=4.8
HFT_NOISE_EDGE=0.9
# Skew (coinbase_recv − poly_recv, ms): коридор с учётом знака.
# Гейт включён при max>0; требуется HFT_ENTRY_MIN_SKEW_MS ≤ skew ≤ HFT_ENTRY_MAX_SKEW_MS.
HFT_ENTRY_MIN_SKEW_MS=-3200.0
HFT_ENTRY_MAX_SKEW_MS=100.0
HFT_ENTRY_MIN_ASK_UP=0.12
HFT_ENTRY_MIN_ASK_DOWN=0.12

# Latency / feeds (093927: latency 1450, soft feed 950, soft entry latency 1800)
HFT_ENTRY_MAX_LATENCY_MS=1450.0
HFT_PHASE_SOFT_MAX_FEED_LATENCY_MS=950.0
HFT_SOFT_ENTRY_MAX_LATENCY_MS=1800.0

# Phase router
HFT_PHASE_SOFT_MIN_ABS_EDGE=5.2
HFT_PHASE_SOFT_MAX_ABS_SPEED=420.0
HFT_PHASE_SOFT_MAX_ABS_EDGE=18.0
HFT_PHASE_VOLATILE_MIN_ABS_SPEED=720.0
HFT_PHASE_VOLATILE_MIN_ABS_EDGE=32.0
HFT_PHASE_SOFT_MIN_TREND_AGE_SEC=1.0

# Ask / spread
HFT_ENTRY_MAX_ASK_UP=0.94
HFT_ENTRY_MAX_ASK_DOWN=0.94
HFT_MAX_ENTRY_SPREAD=0.08

# Z-score
HFT_ENTRY_ZSCORE_TREND_ENABLED=1
HFT_ENTRY_ZSCORE_STRICT_TICKS=2
HFT_ZSCORE_MONOTONIC_STRICTNESS=strict

# Low speed
HFT_ENTRY_LOW_SPEED_EDGE_MULT=2.2
HFT_ENTRY_LOW_SPEED_ABS=1.2

# SL/TP / hold / cooldown
HFT_POLY_SL_MOVE=0.0150
HFT_POLY_TP_MOVE=0.0050
HFT_MIN_HOLD_SEC=3.8
LOSS_COOLDOWN_SEC=5
# Trailing TP (day)
HFT_TRAILING_TP_ACTIVATE_USD=0.08
HFT_TRAILING_TP_PULLBACK_PCT=0.38
HFT_TRAILING_TP_MIN_PULLBACK_USD=0.04

# Regime
HFT_GOOD_REGIME_WINRATE=0.40
HFT_BAD_REGIME_WINRATE=0.33
HFT_RECENT_TRADES_FOR_REGIME=8
HFT_REGIME_COOLDOWN_SEC=45

# Drawdown gate
MAX_DRAWDOWN_PCT=0.20

# Price to beat (Gamma start-of-window; gate also accepts legacy HFT_ANCHOR_*)
HFT_PRICE_TO_BEAT_COUNTER_MIN_DELTA_PCT=0.0005

# Reaction score
HFT_REACTION_MA_PERIOD=21
HFT_REACTION_MACD_FAST=12
HFT_REACTION_MACD_SLOW=26
HFT_REACTION_MACD_SIGNAL=9
HFT_REACTION_MA_REL_SCALE=0.0006
HFT_REACTION_MACD_HIST_SCALE=15.0
HFT_REACTION_W_RSI=0.45
HFT_REACTION_W_MA=0.30
HFT_REACTION_W_MACD=0.25

# RSI entry (wider UP window + gentler slope so BUY_UP isn’t blocked vs DOWN)
HFT_RSI_UP_ENTRY_MAX=57.0
HFT_RSI_UP_SLOPE_MIN=0.30
HFT_RSI_DOWN_ENTRY_MIN=47.0
HFT_RSI_DOWN_SLOPE_MAX=-0.35
HFT_ENTRY_RSI_SLOPE_FILTER_ENABLED=1
# RSI slope exit thresholds (points per tick). Negative for UP exit, positive for DOWN exit.
# UP: exit when RSI slope <= this value (turning down from bullish momentum)
# DOWN: exit when RSI slope >= this value (turning up from bearish momentum)
HFT_RSI_SLOPE_EXIT_UP=-2.0
HFT_RSI_SLOPE_EXIT_DOWN=2.0
# RSI exit bands (extended for day mode to hold positions longer)
HFT_RSI_EXIT_UPPER_BASE=90
HFT_RSI_EXIT_LOWER_BASE=10
HFT_RSI_RANGE_EXIT_BAND_MARGIN=20.0
# Extra RSI points before RSI_RANGE fade exit (not time): higher = less sensitive, safer from noise
HFT_RSI_RANGE_EXIT_FADE_BUFFER=8.0
HFT_RSI_RANGE_EXIT_MIN_HOLD_SEC=2.0

# ADX: short impulse vs Polymarket lag — ~60 ticks ≈ 12–15s at ~4–5 ticks/s (see HFT_ADX_TICK_LEN).
# Larger (120–200) = smoother, slower; smaller (40–60) = faster reaction, noisier.
HFT_ADX_PERIOD=14
HFT_ADX_TICK_LEN=60
