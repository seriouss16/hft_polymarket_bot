# Runtime configuration for HFT bot.
# This file is loaded first. Local .env values override it.

# ---------------------------------------------------------------------
# Global constants (converted from hardcoded values).
# These were previously hardcoded in Python files.
# ---------------------------------------------------------------------
CLOB_BOOK_HTTP=https://clob.polymarket.com/book
DEBUG_LOG_PATH=/mnt/work/DEV/PRJ0/prjBJ_arb_polymarket/.cursor/debug-%session%.log
DEBUG_SESSION_ID=ac56e4

# ---------------------------------------------------------------------
# Calendar-based session profiles (UTC).
# core/session_profile.py selects between two profiles: NIGHT and DAY.
#
# NIGHT — active when any of:
#   • Weekends (Sat/Sun UTC): entire 24 h.
#   • Weekday night: 23:00–06:00 UTC.
#   speed=0  SL=1.5%  TP=0.4%  latency=3000ms  cooldown=3s
#
# DAY — weekday daytime only: 06:00–23:00 UTC (Mon–Fri).
#   speed=±2  z-score=ON  SL=1.0%  TP=0.3%  latency=1350ms  cooldown=5s
#
# Values below are startup defaults; each profile overrides them at runtime.
# MarketRegimeDetector (core/market_regime.py) tracks CALM/MIXED/ACTIVE
# from rolling speed RMS and Poly WS latency for informational logging only.
# ---------------------------------------------------------------------
HFT_NIGHT_START_UTC_HOUR=23
HFT_NIGHT_END_UTC_HOUR=6

# ---------------------------------------------------------------------------
# Market regime auto-detector thresholds (core/market_regime.py).
# REGIME_WINDOW_TICKS    — rolling window size in ticks (default 60, ~15 s).
# REGIME_CALM_SPEED_MAX  — |speed| RMS <= this → CALM (pts/s).
# REGIME_ACTIVE_SPEED_MIN— |speed| RMS >= this → ACTIVE (pts/s).
# REGIME_CALM_STALE_MIN_MS — median latency >= this reinforces CALM.
# REGIME_LOG_MIN_SEC     — min seconds between regime-change log lines.
# ---------------------------------------------------------------------------
REGIME_WINDOW_TICKS=60
# CALM: speed RMS <= 0.5 pts/s (weekend/night flat market).
REGIME_CALM_SPEED_MAX=0.5
# ACTIVE: speed RMS >= 5.0 pts/s (sustained directional momentum).
# Raised from 3.0 to 5.0 to avoid single BTC price spike triggering ACTIVE.
REGIME_ACTIVE_SPEED_MIN=5.0
REGIME_CALM_STALE_MIN_MS=1200
REGIME_LOG_MIN_SEC=120
# Minimum consecutive ticks the new regime must hold before switching.
# 15 ticks ≈ 4 s at 250 ms/tick — filters out sub-second speed spikes.
REGIME_HYSTERESIS_TICKS=15

# ---------------------------------------------------------------------
# Core sizing and risk budget.
# For live mode all four values must be consistent:
#   HFT_DEPOSIT_USD       — session budget (must be <= LIVE_ACCOUNT_BALANCE)
#   HFT_DEFAULT_TRADE_USD — base step per trade (USD); acts as minimum size
#   HFT_TRADE_PCT_OF_DEPOSIT — if > 0: size = step + pct% of profit above
#                              HFT_DEPOSIT_USD; 0 = fixed step only
#   HFT_MAX_POSITION_USD  — hard cap on open exposure; set equal to or below
#                           HFT_DEPOSIT_USD to prevent over-commitment
# ---------------------------------------------------------------------
HFT_DEPOSIT_USD=4
HFT_DEFAULT_TRADE_USD=4
HFT_TRADE_PCT_OF_DEPOSIT=0
HFT_MAX_POSITION_USD=4

# ---------------------------------------------------------------------
# Signal thresholds.
# ---------------------------------------------------------------------
HFT_NOISE_EDGE=0.8
# Min oracle-vs-polymarket price divergence (pts) required to open a position.
# Restored to 4.0/6.0 — the values that produced +138% WR=75.6% in the profitable
# session. Lower values (3.0/4.5) allowed too many low-quality entries.
# Night profile overrides to 3.0 for more frequent entries when volatility is low.
HFT_BUY_EDGE=4.0
HFT_SELL_EDGE_ABS=6.0
# Minimum trend speed (pts/s) for general momentum gating.
# 0.02 is the profitable-session value. Keeps entries anchored to actual momentum.
HFT_SPEED_FLOOR=0.02
HFT_COOLDOWN_SEC=0.5

# ---------------------------------------------------------------------
# Hold and exits.
# ---------------------------------------------------------------------
HFT_MIN_HOLD_SEC=3.0
# Close legacy (HFTEngine) position when fast-vs-poly trend flips against the held side (was debug-only).
HFT_EXIT_ON_OPPOSITE_TREND=1
# Optional: require |edge| >= this (price pts) before TREND_FLIP_EXIT (0 = any flip).
HFT_OPPOSITE_TREND_EXIT_MIN_ABS_EDGE=3.0
# Optional: extra min hold only for trend-flip exit (0 = exit as soon as trend opposes).
HFT_OPPOSITE_TREND_EXIT_MIN_HOLD_SEC=5.5
# Seconds after any SELL close before a new BUY (reduces instant re-entry tail trades). 0 = disabled.
HFT_POST_CLOSE_REENTRY_COOLDOWN_SEC=2
HFT_REACTION_TIMEOUT_SEC=10.0
# Trailing TP: poly-side move required to lock in profit (fraction of price).
# 0.0020 = 0.2% — at 0.60 token this is 0.0012 USD per share, ~$0.007 on 6 sh.
# Weekend markets move in wider ticks; increase to avoid premature exit on noise.
HFT_POLY_TP_MOVE=0.0030
# Trailing SL: poly-side adverse move to trigger stop (fraction of price).
# 0.0040 at price 0.75 = stop after 0.003 USD adverse per share — too tight for
# weekend illiquid books where bid/ask jumps 1-2 ticks randomly.
# Widened to 0.0100 (1%) so normal tick noise at 0.60-0.80 doesn't stop out immediately.
HFT_POLY_SL_MOVE=0.0100
HFT_TARGET_PROFIT_USD=2.5
HFT_STOP_LOSS_USD=1.5
HFT_PNL_TP_PERCENT=0.09
# Raised from 0.07 to 0.20: FAK entry can land 4-6¢ above book ask on illiquid
# books; that spread alone costs ~9% notional — a 7% SL fires instantly.
HFT_PNL_SL_PERCENT=0.20
HFT_PNL_TP_MIN_HOLD_SEC=2.0

# ---------------------------------------------------------------------
# Slot anchor price filter (core/engine.py → _anchor_gate).
# The market resolves "Up" if BTC-end >= BTC-start of the 5-min slot.
# slot_anchor_price = Chainlink BTC/USD captured the moment the slot opens.
#
# HFT_ANCHOR_FILTER_ENABLED=1  — enable the gate (default).
# HFT_ANCHOR_COUNTER_MIN_DELTA_PCT — minimum BTC move (fraction of anchor)
#   required before a counter-anchor entry is allowed.
#   0.0005 = 0.05% of BTC price ≈ ~$0.40 at $80,000 BTC.
#   Set 0.0 to disable the counter-direction block (filter stays aligned only).
# ---------------------------------------------------------------------
HFT_ANCHOR_FILTER_ENABLED=1
HFT_ANCHOR_COUNTER_MIN_DELTA_PCT=0.0005

# ---------------------------------------------------------------------
# Trailing TP/SL: ride the trend, lock profit on pullback.
# Trailing TP: once unrealized >= activate, exit when profit drops pullback_pct from peak (min pullback_usd).
# Trailing SL: once peak profit >= breakeven_at, SL moves to breakeven, then ratchets up by step increments.
# ---------------------------------------------------------------------
HFT_TRAILING_TP_ENABLED=1
# Looser trailing for ~$4 positions: was 0.08/0.40/0.03 → early exits at peak pullback.
HFT_TRAILING_TP_ACTIVATE_USD=0.08
HFT_TRAILING_TP_PULLBACK_PCT=0.40
HFT_TRAILING_TP_MIN_PULLBACK_USD=0.03
HFT_TRAILING_SL_ENABLED=1
HFT_TRAILING_SL_BREAKEVEN_AT_USD=0.04
HFT_TRAILING_SL_STEP_USD=0.03
HFT_TRAILING_SL_STEP_LOCK_PCT=0.50

# ---------------------------------------------------------------------
# RSI entry and exit bands.
#
# Entry bands are ASYMMETRIC by design:
#   BUY_UP   — enter when Rx is LOW (oversold, price likely to rise).
#              Allowed range: 20..55. Above 55 BTC is not oversold enough.
#   BUY_DOWN — enter when Rx is HIGH (overbought, price likely to fall).
#              Allowed range: 45..80. Below 45 BTC is not overbought enough.
# The overlap at 45–55 allows neutral entries when other signals are strong
# (aggressive edge bypass still active via HFT_RSI_ALLOW_BYPASS_AGGRESSIVE_EDGE).
#
# Exit bands (upper/lower) are the TP targets for internal_reversal:
#   upper=85 → UP position: exit when Rx crosses 85 (overbought, TP).
#   lower=15 → DOWN position: exit when Rx crosses 15 (oversold, TP).
# ---------------------------------------------------------------------
HFT_RSI_PRICE_LEN=128
HFT_RSI_ENTRY_UP_LOW=20.0
HFT_RSI_ENTRY_UP_HIGH=55.0
HFT_RSI_ENTRY_DOWN_LOW=45.0
HFT_RSI_ENTRY_DOWN_HIGH=80.0
HFT_RSI_EXIT_UPPER_BASE=85
HFT_RSI_EXIT_LOWER_BASE=15
HFT_RSI_RANGE_EXIT_MIN_PROFIT_USD=0.3
HFT_RSI_RANGE_EXIT_BAND_MARGIN=10.0
HFT_RSI_EXTREME_HIGH=90
HFT_RSI_EXTREME_LOW=10
HFT_RSI_BAND_VOL_K=0.12
HFT_RSI_RANGE_EXIT_PROFIT_FRAC=0.6
HFT_RSI_RANGE_EXIT_MIN_HOLD_SEC=1.5
# Clamp RSI used in exit/fade logic (reduces false 100/0 from short RSI history).
HFT_RSI_EXIT_CLAMP_HIGH=99.0
HFT_RSI_EXIT_CLAMP_LOW=1.0
# If 1, fade exits past the band require unrealized PnL > min profit (no fade-only exit in loss).
HFT_RSI_RANGE_EXIT_FADE_REQUIRE_POSITIVE=1
HFT_RSI_SLOPE_EXIT_ENABLED=1
HFT_RSI_HOLD_UP_FLOOR=40.0
HFT_RSI_HOLD_DOWN_CEILING=60.0
# RSI gate for imbalance-driven internal reversal.
# DOWN position: imbalance only triggers exit when RSI > this value.
# UP  position: imbalance only triggers exit when RSI < (100 - this value).
# Prevents premature exit when RSI is extreme (strong momentum still in play).
HFT_INTERNAL_REVERSAL_IMB_RSI_GATE=20.0
HFT_RSI_ALLOW_BYPASS_STRONG_EDGE=0
HFT_RSI_ALLOW_BYPASS_AGGRESSIVE_EDGE=1

# ---------------------------------------------------------------------
# Additional RSI and logging parameters (converted from hardcoded defaults).
# HFT_RSI_PRICE_LEN and HFT_AGGRESSIVE_ENTRY_LOG_MIN_SEC are defined earlier in this file;
# do not duplicate them here — _load_env_file uses first-wins merge (overwrite=False).
# ---------------------------------------------------------------------
# Deny log seconds for entry cap denials (was hardcoded default 20.0 in engine.py).
HFT_ENTRY_CAP_DENY_LOG_SEC=20.0

# ---------------------------------------------------------------------
# Reaction score (RSI + EMA + MACD histogram), 0–100 like RSI (ml/indicators.py).
# When HFT_REACTION_SCORE_ENABLED=1, the engine feeds this blend into the same
# entry/exit/slope paths as RSI so existing band thresholds apply unchanged.
# Weights should sum to 1.0 for intuitive tuning.
#
# Profile overrides (applied automatically by session_profile.py):
#   NIGHT/WEEKEND — RSI weight raised, shorter MA/MACD periods, smaller scales
#                   because BTC moves in cents, not dollars, during quiet hours.
#   DAY           — MACD and MA get more weight; standard scales for active hours.
# ---------------------------------------------------------------------
HFT_REACTION_SCORE_ENABLED=1
# MA period: night uses 14 (quicker to react to sparse ticks), day uses 21.
HFT_REACTION_MA_PERIOD=14
# MACD periods: night uses fast/slow/signal = 8/17/6 to warm up in ~23 ticks
# instead of 35; reduces the dead zone at session start on sparse WS feeds.
HFT_REACTION_MACD_FAST=8
HFT_REACTION_MACD_SLOW=17
HFT_REACTION_MACD_SIGNAL=6
# MA saturation distance: 0.0003 = 0.03% for night (BTC barely moves);
# session_profile overrides to 0.0006 for day (larger intraday swings).
HFT_REACTION_MA_REL_SCALE=0.0003
# MACD histogram scale in USD: night BTC EMA(8)-EMA(17) hist is ~0.5-3 USD;
# session_profile overrides to 15.0 for day (histogram can reach 10-30 USD).
HFT_REACTION_MACD_HIST_SCALE=3.0
# Night weights: RSI dominant (0.60) because MA/MACD are slow to warm up
# on sparse ticks; MA adds trend confirmation (0.25); MACD shows momentum (0.15).
HFT_REACTION_W_RSI=0.60
HFT_REACTION_W_MA=0.25
HFT_REACTION_W_MACD=0.15

# ---------------------------------------------------------------------
# Entry confirmation and trend filters.
# ---------------------------------------------------------------------
HFT_ENTRY_CONFIRM_AGE_SEC=0.5
HFT_ENTRY_CONFIRM_AGE_STRONG_SEC=1.0
HFT_REVERSAL_CONFIRM_AGE_SEC=0.0
HFT_ENTRY_EXTREME_MIN_EDGE=5.0
HFT_ENTRY_EXTREME_PRICE_LOW=0.20
HFT_ENTRY_EXTREME_PRICE_HIGH=0.80
HFT_ENTRY_DEPTH_MULT=0.85
# Minimum CB price speed (pts/s) for UP/DOWN entry direction check.
# 0.0 disables this check: at night BTC is calm (speed=0 most of the time)
# but edge divergence is real. The profitable daytime session had volatile BTC
# (speed 200-4000 pts/s), so ±2.0 worked. Nighttime = 0.0 to allow entries.
HFT_ENTRY_UP_SPEED_MIN=0.0
HFT_ENTRY_DOWN_SPEED_MAX=0.0
HFT_ENTRY_ACCEL_ENABLED=0
HFT_ENTRY_ACCEL_MIN=0.10
HFT_REVERSAL_SPEED_FLOOR=0.15
HFT_AGGRESSIVE_ENTRY_RELAX_SPEED=-8.0
HFT_AGGRESSIVE_ENTRY_RELAX_SPEED_DOWN=30.0
HFT_AGGRESSIVE_ENTRY_LOG_MIN_SEC=3.0

# ---------------------------------------------------------------------
# Dynamic position sizing.
# HFT_DYNAMIC_AMOUNT_MAX_USD should match HFT_MAX_POSITION_USD.
# HFT_DYNAMIC_AMOUNT_MIN_USD is the floor for tier sizing — automatically
# bypassed when the current balance is below it (floor becomes balance).
# ---------------------------------------------------------------------
HFT_DYNAMIC_RISK_PER_TICK_USD=5.0
HFT_DYNAMIC_AMOUNT_MIN_USD=20.0
HFT_DYNAMIC_AMOUNT_MAX_USD=100.0
HFT_DYNAMIC_CHEAP_PRICE_BELOW=0.30
HFT_DYNAMIC_RICH_PRICE_ABOVE=0.70
HFT_DYNAMIC_MIN_EXEC_PRICE=0.01
HFT_DYNAMIC_FLOOR_NOTIONAL_USD=30.0
HFT_DYNAMIC_AMOUNT_CHEAP_USD=45.0
HFT_DYNAMIC_AMOUNT_RICH_USD=80.0

# ---------------------------------------------------------------------
# Order book and liquidity gates.
# ---------------------------------------------------------------------
HFT_BOOK_MOVE_ENTRY_MIN=0.0001
HFT_BOOK_MOVE_STOP_MAX=0.0012
HFT_BOOK_STALL_TICKS=30
HFT_MAX_ENTRY_SPREAD=0.05
HFT_ENTRY_LIQUIDITY_MAX_SPREAD=0.08
HFT_MAX_ENTRY_ASK=0.99
# Used by LiveExecutionEngine (live_engine.py); old code default 0.08.
HFT_MIN_ENTRY_ASK=0.08
# Entry guards by outcome ask: skip entries cheaper than 8c or richer than 97c.
# MAX_ASK_DOWN=0.78: with $4 budget, DOWN token at 0.80+ yields < 5 shares (CLOB min).
# 5 shares × $0.78 = $3.90 → fits in $4.00 budget with room for fees.
# Adjust upward if deposit is increased.
HFT_ENTRY_MIN_ASK_UP=0.08
HFT_ENTRY_MAX_ASK_UP=0.97
HFT_ENTRY_MIN_ASK_DOWN=0.08
# Upper cap for DOWN token ask. Set to 0.97 (same as UP) — no static budget-based
# restriction here. The live budget check in bot.py (cost_usd / entry_ask < MIN_SHARES)
# handles insufficient balance dynamically so increasing the deposit to $10+ just works.
HFT_ENTRY_MAX_ASK_DOWN=0.97
# strong_rsi threshold = buy_edge * STRONG_EDGE_RSI_MULT = 4.0 * 2.0 = 8.0 pts
# Restored to profitable-session value of 2.0.
HFT_STRONG_EDGE_RSI_MULT=2.0
HFT_AGGRESSIVE_EDGE_MULT=3.0
# Minimum trend age (seconds) for STRONG JUMP early entry; 0 disables the gate.
HFT_STRONG_JUMP_MIN_TREND_AGE_SEC=0.0
# Minimum edge (pts) for legacy spread bypass in spread_gate_legacy.
# Restored to 12.0 from profitable session.
HFT_WIDE_SPREAD_MIN_EDGE=12.0
HFT_ENTRY_MOMENTUM_ALT_ENABLED=1

# ---------------------------------------------------------------------
# Latency and slot-time protections.
# ---------------------------------------------------------------------
# Staleness gate uses max(cb_age, poly_age, bn_age); Poly oracle often >1s — keep headroom.
# Night sessions: Polymarket WS updates are sparse (book stale 1-2s is normal when
# market is quiet). Increased from 1350 to 2500 to allow entries during low-activity periods.
HFT_ENTRY_MAX_LATENCY_MS=3500.0
# Block entries when |coinbase_recv - poly_recv| exceeds this (ms). 0 is too strict:
# local WS ordering produces false skew; use ~1.5 s headroom (night profile overrides higher).
HFT_ENTRY_MAX_SKEW_MS=2000.0
HFT_LATENCY_HIGH_MS=400.0
HFT_LATENCY_HIGH_EDGE_MULT=1.3
HFT_EXPIRY_TIGHT_SEC=30.0
HFT_EXPIRY_EDGE_MULT=2.0
HFT_SLOT_INTERVAL_SEC=300.0
HFT_NO_ENTRY_FIRST_SEC=5.0
HFT_NO_ENTRY_LAST_SEC=45.0
# End of slot: force SELL when sec_left <= this (default 3). 99c book exit only if sec_left < HFT_SLOT_99C_MAX_SEC (20).
HFT_SLOT_FORCE_CLOSE_LAST_SEC=3.0
HFT_SLOT_99C_MAX_SEC=20.0
HFT_SLOT_EXPIRY_INFO_MAX_SEC=45.0
# Min seconds between "Entry blocked by spread_gate" logs.
HFT_FEED_GATE_LOG_MIN_SEC=30.0
# After Trend cross, wait before entry; 2s blocks fast post-flip signals.
HFT_TREND_FLIP_MIN_AGE_SEC=0.0
# When CB price speed < LOW_SPEED_ABS, required edge is multiplied by LOW_SPEED_EDGE_MULT
# (chop/fade protection).  With BTC calm periods speed=0, this multiplied buy_edge
# from 4.0 to 8.0 — blocking all entries while max real edge was 5.6 pts.
# Restored to profitable-session values: ABS=1.0, MULT=2.0.
# With BUY_EDGE=4.0, low-speed required edge = 4.0 * 2.0 = 8.0 pts — filters choppy low-momentum entries.
HFT_ENTRY_LOW_SPEED_ABS=1.0
HFT_ENTRY_LOW_SPEED_EDGE_MULT=2.0
# Wider one-tick edge step when not in bypass (anti-spoof still applies in chop).
HFT_ENTRY_MAX_EDGE_JUMP_PTS=14.0
# When |oracle edge speed| >= this (pts/s), allow large edge jumps and skip z-score monotonicity.
# Speed bypass: when trend speed >= this, skip monotonicity and edge-jump checks.
# Restored to 90.0 from profitable session. Z-score is re-enabled with STRICT_TICKS=2,
# so bypass is now the safety valve for fast-momentum moves (speed ≥ 90 pts/s).
HFT_ENTRY_EDGE_JUMP_BYPASS_ABS_SPEED=90.0
HFT_ENTRY_ZSCORE_BYPASS_ABS_SPEED=90.0
HFT_AGGRESSIVE_MIN_TREND_AGE_SEC=0.0
HFT_NO_ENTRY_GUARDS=0

# ---------------------------------------------------------------------
# Context filters (RSI slope, z-score, CEX imbalance).
#
# When HFT_ENTRY_RSI_SLOPE_FILTER_ENABLED=1, slope-mode REPLACES the simple
# in-band check and requires:
#   BUY_UP:   Rx < HFT_RSI_UP_ENTRY_MAX  AND  slope > HFT_RSI_UP_SLOPE_MIN
#   BUY_DOWN: Rx > HFT_RSI_DOWN_ENTRY_MIN AND  slope < HFT_RSI_DOWN_SLOPE_MAX
#
# Night/weekend: slope thresholds are relaxed (0.0) because Rx changes slowly
# on sparse Poly WS ticks.  The asymmetric entry bands above (UP_HIGH=55,
# DOWN_LOW=45) already enforce directionality — slope just confirms momentum.
# Aggressive-edge bypass (HFT_RSI_ALLOW_BYPASS_AGGRESSIVE_EDGE=1) ensures
# large oracle divergences still fire regardless of slope.
# ---------------------------------------------------------------------
HFT_ENTRY_RSI_SLOPE_FILTER_ENABLED=1
HFT_RSI_UP_ENTRY_MAX=55.0
HFT_RSI_UP_SLOPE_MIN=0.0
HFT_RSI_DOWN_ENTRY_MIN=45.0
HFT_RSI_DOWN_SLOPE_MAX=0.0
# Z-score monotonicity check for entry.
# Disabled: Z-score is chaotic (0.00/+0.01/-0.01/+6.86) due to feed timing jitter.
# Z-score filter: disabled for night sessions where BTC is flat (speed=0) and
# z-score is choppy even with real edge divergence. The profitable daytime session
# had trending BTC where z-score was naturally monotonic. Nighttime: 0/1 (off/relaxed).
# Speed bypass (BYPASS_ABS_SPEED=90) is the safety valve for fast momentum breaks.
HFT_ENTRY_ZSCORE_TREND_ENABLED=0
HFT_ENTRY_ZSCORE_STRICT_TICKS=1
# HFT_ENTRY_CEX_IMBALANCE_ENABLED removed — CEX bid imbalance was never wired
# from bot.py into process_tick(), so the filter was always a no-op (True).
# Poly orderbook imbalance (bid_size_top / total) is used directly inside engine.py.

# ---------------------------------------------------------------------
# Regime filter and simulator controls.
# Softer regime: shorter memory, easier "good" path, harder cooldown trigger, shorter pause.
# ---------------------------------------------------------------------
HFT_SIM_FEE_RATE=0.001
HFT_RECENT_TRADES_FOR_REGIME=6
HFT_GOOD_REGIME_WINRATE=0.38
HFT_BAD_REGIME_WINRATE=0.28
HFT_REGIME_COOLDOWN_SEC=30
HFT_REGIME_FILTER_ENABLED=1
# When 1, soft_flow profile ignores rolling bad-regime / cooldown so entries can resume (latency still gated).
HFT_REGIME_BYPASS_SOFT_FLOW=1
HFT_REGIME_SKIP_LOG_MIN_SEC=15
HFT_SLOT_EXPIRY_INFO_LOG_MIN_SEC=8

# ---------------------------------------------------------------------
# Market phase: latency vs soft_flow on one engine (PhaseRouterStrategy).
# Set HFT_ENABLE_PHASE_ROUTING=1 and HFT_ACTIVE_STRATEGY=phase_router to enable.
# Soft_flow: directional UP/DOWN, bounded speed/edge, fresh feed; FLAT or bursts use latency.
# ---------------------------------------------------------------------
HFT_ENABLE_PHASE_ROUTING=1
HFT_LOG_MARKET_PROFILE=0
HFT_PHASE_SOFT_FLOW_ENABLE=1
# Faster entry after trend change (was 1.8s).
HFT_PHASE_SOFT_MIN_TREND_AGE_SEC=1.0
# Minimum |edge| to consider soft_flow. Lowered from 8.0 → 4.0 for night/weekend
# to catch more entries when market is slow but directional.
# Speed limit raised: 55 → 400 to allow entries during volatile night moves.
HFT_PHASE_SOFT_MIN_ABS_EDGE=4.0
HFT_PHASE_SOFT_MAX_ABS_SPEED=400.0
HFT_PHASE_SOFT_MAX_ABS_EDGE=18.0
# Soft flow latency: was 800 ms — too tight for night/weekend sparse Poly WS.
# Raised to 2000 ms to align with night profile staleness tolerance.
HFT_PHASE_SOFT_MAX_FEED_LATENCY_MS=2200.0
# Volatile thresholds: raised to allow latency profile during fast moves.
HFT_PHASE_VOLATILE_MIN_ABS_EDGE=35.0
HFT_PHASE_VOLATILE_MIN_ABS_SPEED=600.0
HFT_SOFT_NOISE_EDGE=2.5
HFT_SOFT_BUY_EDGE=10.0
HFT_SOFT_ENTRY_CONFIRM_AGE_SEC=1.0
HFT_SOFT_ENTRY_CONFIRM_AGE_STRONG_SEC=2.0
# Old engine defaults for soft_flow profile (engine._build_soft_flow_profile).
HFT_SOFT_STRONG_EDGE_RSI_MULT=2.5
HFT_SOFT_ENTRY_AGGRESSIVE_MIN_TREND_AGE_SEC=1.0
HFT_SOFT_AGGRESSIVE_EDGE_MULT=8.0
HFT_SOFT_ENTRY_MOMENTUM_ALT_ENABLED=0
HFT_SOFT_ENTRY_MAX_EDGE_JUMP_PTS=4.0
# Soft entry latency tolerance: relaxed from 750 ms → 1800 ms for night/weekend.
HFT_SOFT_ENTRY_MAX_LATENCY_MS=1800
HFT_SOFT_ENTRY_LOW_SPEED_ABS=1.0
HFT_SOFT_ENTRY_LOW_SPEED_EDGE_MULT=2.0
HFT_SOFT_RSI_ALLOW_BYPASS_AGGRESSIVE_EDGE=0
# Force one profile for isolated windows: "soft_flow", "latency", or empty for auto-router.
HFT_PHASE_FORCE_PROFILE=
HFT_LOG_PHASE_DIAGNOSTICS=1
HFT_LOG_PHASE_DIAGNOSTICS_SEC=45
HFT_PERF_RESET_ON_NEW_MARKET=0

# ---------------------------------------------------------------------
# Strategy hub controls.
# ---------------------------------------------------------------------
HFT_ACTIVE_STRATEGY=phase_router
# Choose strategy that generates LIVE entry signals; set empty/unknown to fall back to active strategy.
HFT_LIVE_SIGNAL_STRATEGY=latency_arbitrage
HFT_PARALLEL_STRATEGIES=0

# ---------------------------------------------------------------------
# Main loop and diagnostics.
# ---------------------------------------------------------------------
HFT_LOG_DEDUPE_SAME_MSG_SEC=1.0
# 0 = respect drawdown Gate (stop SIM entries when Gate is OFF).
# 1 = bypass gate (SIM trades even when Gate is OFF due to drawdown).
# Set to 0 to prevent compounding losses during drawdown streaks.
HFT_BYPASS_META_GATE=0
# Strategy review cadence in minutes for A/B isolation runs.
HFT_REVIEW_WINDOW_MIN=20
HFT_FILTER_DIAG_LOG_SEC=20
HFT_FAST_LOG_MIN_SEC=0.25
HFT_LOOP_SLEEP_SEC=0
HFT_ENABLE_LSTM=0
HFT_SLOT_POLL_SEC=0
HFT_NETWORK_TIMING_DEBUG=0
# Suppress urllib3/requests connection DEBUG spam; set DEBUG to trace HTTP clients.
HFT_HTTP_CLIENT_LOG_LEVEL=WARNING
# Reuse Gamma JSON within TTL to avoid duplicate GETs for the same slug in one loop.
HFT_GAMMA_CACHE_TTL_SEC=2.0
HFT_USE_UVLOOP=1
# After live skip (slippage etc.); bot.py (old default 30.0).
LIVE_SKIP_COOLDOWN_SEC=30.0
HFT_WS_RECONNECT_SEC=1

# ---------------------------------------------------------------------
# Bot-level behavior and limits.
# ---------------------------------------------------------------------
# Smart fast: blend Binance vs Coinbase (see data/aggregator.py).
USE_SMART_FAST=0
# Typical USDT/USD + venue offset (median from log; tune per session). When >0, excess = drift - baseline; blend only if |excess| > HFT_SMART_EXCESS_THRESHOLD_USD.
HFT_SMART_CB_BN_BASELINE_USD=26
# Slightly tighter so BN-led spikes pull fast price sooner (USD residual after baseline).
HFT_SMART_EXCESS_THRESHOLD_USD=4
HFT_SMART_BINANCE_BLEND=0.7
# Legacy path when baseline=0: blend full drift if |drift| > threshold (USD).
HFT_SMART_DRIFT_THRESHOLD_USD=20
STATS_INTERVAL_SEC=120
PULSE_INTERVAL_SEC=0
CLOB_BOOK_PULL_SEC=2
# HTTP retries for orderbook snapshot (live_engine.py; old default 3).
CLOB_ORDERBOOK_RETRIES=3
LSTM_INFERENCE_SEC=0
# ---------------------------------------------------------------------
# REQUIRED — bot will abort at startup if any of these are missing.
# Sim: HFT_DEPOSIT_USD, HFT_BUY_EDGE, HFT_SELL_EDGE_ABS, HFT_MIN_HOLD_SEC,
#      HFT_OPPOSITE_TREND_EXIT_MIN_HOLD_SEC, HFT_REGIME_FILTER_ENABLED,
#      HFT_TRAILING_TP_ENABLED, HFT_TRAILING_SL_ENABLED, STATS_INTERVAL_SEC.
# Live (LIVE_MODE=1 additionally): all keys below + PRIVATE_KEY, POLY_FUNDER_ADDRESS,
#      POLY_SIGNATURE_TYPE.
# Default signature type for py_clob_client (2 = EOA proxy; set in .env if different).
POLY_SIGNATURE_TYPE=2
# ---------------------------------------------------------------------
# Live mode sizing checklist — keep these four values consistent:
#
#   LIVE_ACCOUNT_BALANCE  — real USDC on Polymarket (0 = skip offline check)
#   HFT_DEPOSIT_USD       — session budget; must be <= LIVE_ACCOUNT_BALANCE
#   HFT_MAX_POSITION_USD  — max open exposure; set <= HFT_DEPOSIT_USD
#   LIVE_ORDER_SIZE       — fallback trade notional (USD) used only when the
#                           simulation engine does not supply cost_usd; set equal
#                           to HFT_DEFAULT_TRADE_USD for consistency
#
# Example for $2 live test:
#   LIVE_ACCOUNT_BALANCE=2  HFT_DEPOSIT_USD=2  HFT_MAX_POSITION_USD=2
#   HFT_DEFAULT_TRADE_USD=2  LIVE_ORDER_SIZE=2
#
# POLY_CLOB_MIN_SHARES — CLOB rejects orders below this number of shares.
#   At price 0.50 a $2 budget gives 4 shares → entry skipped (logged as warning).
#   Lower the token price or raise LIVE_ORDER_SIZE to clear the minimum.
# LIVE_MODE intentionally NOT set here — activate only via shell:
#   LIVE_MODE=1 python -m hft_bot.bot
# or via a dedicated launch script to prevent accidental real-money runs.
LIVE_MODE=0
LIVE_ACCOUNT_BALANCE=4
LIVE_ORDER_SIZE=4
# Polymarket CLOB hard minimum for limit orders is 5 shares.
# Keep at 5; protocol fee (~1%) is accounted for separately in execute().
POLY_CLOB_MIN_SHARES=5
# Spread of the DOWN/UP token CLOB at order placement time.
# Tokens priced at 0.08-0.25 routinely have spreads of 0.10-0.20 during volatility.
# Setting too tight blocks valid high-edge entries; setting too wide risks
# entering on illiquid books where the fill price is far from mid.
# Recommended: 0.15 for small deposits / low-priced tokens.
LIVE_MAX_SPREAD=0.15
# Daily loss limit must be calibrated to LIVE_ACCOUNT_BALANCE.
# Current: $2 balance → cap losses at $1 (50% of balance).
LIVE_MAX_DAILY_LOSS=-1.0
# BUY order price offset relative to best_ask.
# 0.0  = pay exactly ask (immediate fill, no reprice risk).
# -0.002 = 0.2c below ask (passive, risks stale/reprice on fast markets).
# +0.001 = 0.1c above ask (crosses spread, guarantees fill on liquid books).
# +0.002 helps immediate_fill on fast DOWN/UP books; 0.0 often leaves GTC stale → reprice abort.
LIVE_BUY_PRICE_OFFSET=0.002
# Order lifecycle: poll interval, stale timeout, max reprice attempts before emergency exit.
LIVE_ORDER_FILL_POLL_SEC=0.4
LIVE_ORDER_STALE_SEC=3.0
LIVE_ORDER_MAX_REPRICE=2
# After canceling a stale order before reprice: wait and poll the old order id so a
# fill that races with cancel is detected (avoids bogus reprice 400 and force-clear).
LIVE_REPRICE_POST_CANCEL_SLEEP_SEC=0.35
LIVE_REPRICE_POST_CANCEL_FILL_POLLS=8
LIVE_REPRICE_POST_CANCEL_POLL_SEC=0.12
# Max adverse move (absolute 0-1 price) vs best_ask at first BUY placement. If the
# stale reprice would lift the limit above entry_best_ask + this, cancel entry.
# 0 = disabled (always reprice toward current ask). Example: 0.04 = skip if ask rose >4c.
LIVE_MAX_BUY_REPRICE_SLIPPAGE=0
# Minimum fraction of CLOB-reported fill required to accept an on-chain balance
# reading as "settled". Reads below this fraction are treated as ledger lag and
# retried. Prevents a tiny partial ledger snapshot from being misread as a
# post-fee balance (causing phantom BUY + failed FAK sell).
LIVE_BALANCE_MIN_FRAC=0.10
# 0 (default): do not record live_open unless on-chain conditional balance confirms
# the BUY after retries (stays in sync with debits). 1 = trust CLOB fill if API lags.
LIVE_TRUST_CLOB_WITHOUT_CHAIN_BALANCE=0
MAX_DRAWDOWN_PCT=0.25
MAX_POSITION_PCT=0.10
# After a losing trade, block new entries for this many seconds.
# 30s cooldown caused the bot to miss the entire DOWN-token rally (0.70→0.96)
# that started right after the losing exit. Reduced to 5s to allow re-entry
# if a new strong signal appears, while still preventing immediate revenge trading.
LOSS_COOLDOWN_SEC=5
HFT_LOG_KEEP_FILES=100

# ---------------------------------------------------------------------
# Live execution parameters (converted from hardcoded defaults).
# ---------------------------------------------------------------------
# HTTP timeout for CLOB orderbook requests (seconds).
LIVE_CLOB_BOOK_HTTP_TIMEOUT=1.5
# Emergency ticks threshold for order cancellation.
LIVE_ORDER_EMERGENCY_TICKS=3
# Wait this many seconds after order fill before checking chain balance.
LIVE_CLOSE_WAIT_PENDING_SEC=8.0
# Delays for chain balance probing during close (comma-separated seconds).
LIVE_CLOSE_CHAIN_PROBE_DELAYS_SEC=0,0.15,0.35,0.6,1.0,1.5
# Dust threshold for chain sell remainder handling (shares).
LIVE_SELL_CHAIN_DUST_SHARES=0.02
# Delays for sell balance wait retries (comma-separated seconds).
LIVE_SELL_BALANCE_WAIT_DELAYS_SEC=0,0.25,0.5,1.0,1.5,2.0
# Delay after sell before checking chain balance (seconds).
LIVE_POST_SELL_CHAIN_DELAY_SEC=0.5
# Number of attempts to place a sell order.
LIVE_SELL_PLACE_ATTEMPTS=5
# Sleep between sell placement retries (seconds).
LIVE_SELL_PLACE_RETRY_SLEEP_SEC=0.35
# Number of FAK sell attempts after GTC fails.
LIVE_SELL_FAK_ATTEMPTS=4
# Sleep between FAK retries (seconds).
LIVE_SELL_FAK_RETRY_SLEEP_SEC=0.4
# Dust threshold for inventory cleanup (shares).
LIVE_INVENTORY_DUST_SHARES=0.05
# Skip presell balance check when 1.
LIVE_SKIP_PRESELL_BALANCE=0
# Safety factor for buy collateral calculation (0-1).
LIVE_BUY_COLLATERAL_SAFETY=0.995
# Skip stats logging interval (seconds).
HFT_LIVE_SKIP_STATS_LOG_SEC=30.0
