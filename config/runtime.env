# Runtime configuration for HFT bot.
# This file is loaded first. Local .env values override it.

# ---------------------------------------------------------------------
# Core sizing and risk budget.
# ---------------------------------------------------------------------
HFT_DEPOSIT_USD=100
HFT_DEFAULT_TRADE_USD=10
HFT_TRADE_PCT_OF_DEPOSIT=0
HFT_MAX_POSITION_USD=100

# ---------------------------------------------------------------------
# Signal thresholds.
# ---------------------------------------------------------------------
HFT_NOISE_EDGE=0.8
HFT_BUY_EDGE=2.5
HFT_SELL_EDGE_ABS=5.0
HFT_SPEED_FLOOR=0.02
HFT_COOLDOWN_SEC=0.05

# ---------------------------------------------------------------------
# Hold and exits.
# ---------------------------------------------------------------------
HFT_MIN_HOLD_SEC=2.0
HFT_REACTION_TIMEOUT_SEC=10.0
HFT_POLY_TP_MOVE=0.0030
HFT_POLY_SL_MOVE=0.0025
HFT_TARGET_PROFIT_USD=2.5
HFT_STOP_LOSS_USD=1.5
HFT_PNL_TP_PERCENT=0.07
HFT_PNL_SL_PERCENT=0.05
HFT_PNL_TP_MIN_HOLD_SEC=2.0

# ---------------------------------------------------------------------
# RSI entry and exit bands.
# ---------------------------------------------------------------------
HFT_RSI_PRICE_LEN=128
HFT_RSI_ENTRY_UP_LOW=20.0
HFT_RSI_ENTRY_UP_HIGH=80.0
HFT_RSI_ENTRY_DOWN_LOW=20.0
HFT_RSI_ENTRY_DOWN_HIGH=80.0
HFT_RSI_EXIT_UPPER_BASE=85
HFT_RSI_EXIT_LOWER_BASE=15
HFT_RSI_RANGE_EXIT_MIN_PROFIT_USD=0.3
HFT_RSI_RANGE_EXIT_BAND_MARGIN=10.0
HFT_RSI_EXTREME_HIGH=90
HFT_RSI_EXTREME_LOW=10
HFT_RSI_BAND_VOL_K=0.12
HFT_RSI_RANGE_EXIT_PROFIT_FRAC=0.6
HFT_RSI_SLOPE_EXIT_ENABLED=1
HFT_RSI_HOLD_UP_FLOOR=40.0
HFT_RSI_HOLD_DOWN_CEILING=60.0
HFT_RSI_ALLOW_BYPASS_STRONG_EDGE=0
HFT_RSI_ALLOW_BYPASS_AGGRESSIVE_EDGE=1

# ---------------------------------------------------------------------
# Entry confirmation and trend filters.
# ---------------------------------------------------------------------
HFT_ENTRY_CONFIRM_AGE_SEC=0.1
HFT_ENTRY_CONFIRM_AGE_STRONG_SEC=0.35
HFT_REVERSAL_CONFIRM_AGE_SEC=0.2
HFT_ENTRY_EXTREME_MIN_EDGE=5.0
HFT_ENTRY_EXTREME_PRICE_LOW=0.20
HFT_ENTRY_EXTREME_PRICE_HIGH=0.80
HFT_ENTRY_DEPTH_MULT=0.85
HFT_ENTRY_UP_SPEED_MIN=2.0
HFT_ENTRY_DOWN_SPEED_MAX=-2.0
HFT_ENTRY_ACCEL_ENABLED=0
HFT_ENTRY_ACCEL_MIN=0.10
HFT_REVERSAL_SPEED_FLOOR=0.15
HFT_AGGRESSIVE_ENTRY_RELAX_SPEED=-8.0
HFT_AGGRESSIVE_ENTRY_RELAX_SPEED_DOWN=30.0

# ---------------------------------------------------------------------
# Dynamic position sizing.
# ---------------------------------------------------------------------
HFT_DYNAMIC_RISK_PER_TICK_USD=5.0
HFT_DYNAMIC_AMOUNT_MIN_USD=20.0
HFT_DYNAMIC_AMOUNT_MAX_USD=100.0
HFT_DYNAMIC_CHEAP_PRICE_BELOW=0.30
HFT_DYNAMIC_RICH_PRICE_ABOVE=0.70
HFT_DYNAMIC_MIN_EXEC_PRICE=0.01
HFT_DYNAMIC_FLOOR_NOTIONAL_USD=30.0
HFT_DYNAMIC_AMOUNT_CHEAP_USD=45.0
HFT_DYNAMIC_AMOUNT_RICH_USD=80.0

# ---------------------------------------------------------------------
# Order book and liquidity gates.
# ---------------------------------------------------------------------
HFT_BOOK_MOVE_ENTRY_MIN=0.0001
HFT_BOOK_MOVE_STOP_MAX=0.0008
HFT_BOOK_STALL_TICKS=30
HFT_MAX_ENTRY_SPREAD=0.015
HFT_ENTRY_LIQUIDITY_MAX_SPREAD=0.03
HFT_MAX_ENTRY_ASK=0.99
HFT_STRONG_EDGE_RSI_MULT=2.0
HFT_AGGRESSIVE_EDGE_MULT=3.0
HFT_WIDE_SPREAD_MIN_EDGE=12.0
HFT_ENTRY_MOMENTUM_ALT_ENABLED=1

# ---------------------------------------------------------------------
# Latency and slot-time protections.
# ---------------------------------------------------------------------
HFT_ENTRY_MAX_LATENCY_MS=1200.0
HFT_LATENCY_HIGH_MS=400.0
HFT_LATENCY_HIGH_EDGE_MULT=1.3
HFT_EXPIRY_TIGHT_SEC=30.0
HFT_EXPIRY_EDGE_MULT=2.0
HFT_SLOT_INTERVAL_SEC=300.0
HFT_NO_ENTRY_FIRST_SEC=5.0
HFT_NO_ENTRY_LAST_SEC=20.0
HFT_TREND_FLIP_MIN_AGE_SEC=2.0
HFT_ENTRY_LOW_SPEED_ABS=1.0
HFT_ENTRY_LOW_SPEED_EDGE_MULT=2.0
HFT_ENTRY_MAX_EDGE_JUMP_PTS=8.0
HFT_AGGRESSIVE_MIN_TREND_AGE_SEC=0.0
HFT_NO_ENTRY_GUARDS=0

# ---------------------------------------------------------------------
# Context filters (RSI slope, z-score, CEX imbalance).
# ---------------------------------------------------------------------
HFT_ENTRY_RSI_SLOPE_FILTER_ENABLED=0
HFT_RSI_UP_ENTRY_MAX=50.0
HFT_RSI_UP_SLOPE_MIN=0.0
HFT_RSI_DOWN_ENTRY_MIN=50.0
HFT_RSI_DOWN_SLOPE_MAX=0.0
HFT_ENTRY_ZSCORE_TREND_ENABLED=1
HFT_ENTRY_ZSCORE_STRICT_TICKS=2
HFT_ENTRY_CEX_IMBALANCE_ENABLED=1
HFT_CEX_IMBALANCE_UP_MIN=0.60
HFT_CEX_IMBALANCE_DOWN_MAX=0.40

# ---------------------------------------------------------------------
# Regime filter and simulator controls.
# Softer regime: shorter memory, easier "good" path, harder cooldown trigger, shorter pause.
# ---------------------------------------------------------------------
HFT_SIM_FEE_RATE=0.001
HFT_RECENT_TRADES_FOR_REGIME=8
HFT_GOOD_REGIME_WINRATE=0.42
HFT_BAD_REGIME_WINRATE=0.35
HFT_REGIME_COOLDOWN_SEC=60

# ---------------------------------------------------------------------
# Strategy hub controls.
# ---------------------------------------------------------------------
HFT_ACTIVE_STRATEGY=latency_arbitrage
HFT_PARALLEL_STRATEGIES=0

# ---------------------------------------------------------------------
# Main loop and diagnostics.
# ---------------------------------------------------------------------
HFT_BYPASS_META_GATE=1
HFT_FAST_LOG_MIN_SEC=0.25
HFT_LOOP_SLEEP_SEC=0
HFT_ENABLE_LSTM=0
HFT_SLOT_POLL_SEC=0
HFT_NETWORK_TIMING_DEBUG=0
HFT_USE_UVLOOP=1
HFT_WS_RECONNECT_SEC=0

# ---------------------------------------------------------------------
# Bot-level behavior and limits.
# ---------------------------------------------------------------------
LIVE_MODE=0
USE_SMART_FAST=0
STATS_INTERVAL_SEC=120
PULSE_INTERVAL_SEC=0
CLOB_BOOK_PULL_SEC=0
LSTM_INFERENCE_SEC=0
LIVE_ORDER_SIZE=10
LIVE_MAX_SPREAD=1.0
LIVE_MAX_DAILY_LOSS=-1e12
MAX_DRAWDOWN_PCT=0.99
MAX_POSITION_PCT=1.0
LOSS_COOLDOWN_SEC=0
HFT_LOG_KEEP_FILES=5
