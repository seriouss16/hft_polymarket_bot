# Live CLOB / execution defaults (merged after config/runtime.env).
# LIVE_MODE, PRIVATE_KEY, POLY_FUNDER_ADDRESS, account sizing, BUY offset/slippage — .env
# Merge order: see bot_runtime.load_runtime_env()

# Main loop: cooldown after live skip (slippage abort, etc.)
LIVE_SKIP_COOLDOWN_SEC=30.0

# ---------------------------------------------------------------------
# Book age, user WS, order polling / reconcile
# ---------------------------------------------------------------------
LIVE_MAX_BOOK_AGE_SEC=5
LIVE_ORDER_WS_TIMEOUT_SEC=10
# HTTP fill polling interval (seconds); 0 disables legacy polling loop.
LIVE_ORDER_FILL_POLL_SEC=0.2
LIVE_REPRICE_POST_CANCEL_WS_FIRST=1
LIVE_ORDER_RECONCILE_ON_WS_RECONNECT=1

# ---------------------------------------------------------------------
# Spread, legacy daily cap (→ LIVE_MAX_SESSION_LOSS migration), order lifecycle
# ---------------------------------------------------------------------
# Spread of the DOWN/UP token CLOB at order placement time.
# Tokens priced at 0.08-0.25 routinely have spreads of 0.10-0.20 during volatility.
LIVE_MAX_SPREAD=0.15
# Legacy: copied to LIVE_MAX_SESSION_LOSS at startup if the latter is unset.
LIVE_MAX_DAILY_LOSS=-1.0
# LIVE_BUY_PRICE_OFFSET / LIVE_MAX_BUY_REPRICE_SLIPPAGE — usually .env
LIVE_ORDER_STALE_SEC=1.0
LIVE_ORDER_MAX_REPRICE=1
# After cancel before reprice: wait and poll old order id (fill racing cancel).
LIVE_REPRICE_POST_CANCEL_SLEEP_SEC=0.35
LIVE_REPRICE_POST_CANCEL_FILL_POLLS=8
LIVE_REPRICE_POST_CANCEL_POLL_SEC=0.12
# Min CLOB fill fraction before accepting on-chain balance as settled.
LIVE_BALANCE_MIN_FRAC=0.10
# 0 = require chain confirmation after BUY; 1 = trust CLOB if API lags.
LIVE_TRUST_CLOB_WITHOUT_CHAIN_BALANCE=0

# ---------------------------------------------------------------------
# Live execution (live_engine.py, live_common.py)
# ---------------------------------------------------------------------
LIVE_CLOB_BOOK_HTTP_TIMEOUT=1.5
LIVE_ORDER_EMERGENCY_TICKS=3
LIVE_CLOSE_WAIT_PENDING_SEC=8.0
LIVE_CLOSE_CHAIN_PROBE_DELAYS_SEC=0,0.15,0.35,0.6,1.0,1.5
LIVE_SELL_CHAIN_DUST_SHARES=0.02
LIVE_SELL_BALANCE_WAIT_DELAYS_SEC=0,0.25,0.5,1.0,1.5,2.0
LIVE_POST_SELL_CHAIN_DELAY_SEC=0.5
LIVE_SELL_PLACE_ATTEMPTS=5
LIVE_SELL_PLACE_RETRY_SLEEP_SEC=0.35
LIVE_SELL_FAK_ATTEMPTS=4
LIVE_SELL_FAK_RETRY_SLEEP_SEC=0.4
LIVE_INVENTORY_DUST_SHARES=0.05
LIVE_SKIP_PRESELL_BALANCE=0
LIVE_BUY_COLLATERAL_SAFETY=0.995
HFT_LIVE_SKIP_STATS_LOG_SEC=30.0
LIVE_HEARTBEAT_INTERVAL_SEC=5.0
LIVE_BALANCE_CONFIRM_DELAYS_SEC=0,0.15,0.35,0.6,1.0,1.5
LIVE_FAK_SELL_WORST_BID_MULT=0.995
LIVE_SELL_GTC_OFFSET_FROM_BID=-0.002
