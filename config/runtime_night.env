# Session profile NIGHT (weekend all day; weekday 23:00–06:00 UTC).
# Applied via core/session_profile.py — overrides process env for listed keys only.
#
# Baseline: same SL/TP/reaction/RSI/regime as runtime_day.env where not overridden below.
#
# NIGHT entry tuning: speed=0 makes z-score trend gate noisy; cheap DOWN asks are allowed vs
# DAY min asks (see runtime_day.env HFT_ENTRY_MIN_ASK_*). Higher latency budget for sparse feeds.

# --- NIGHT ONLY: speed off, wider latency/skew (feeds slower overnight) ---
HFT_ENTRY_UP_SPEED_MIN=0.0
HFT_ENTRY_DOWN_SPEED_MAX=0.0
HFT_SPEED_FLOOR=0.0
HFT_ENTRY_MAX_LATENCY_MS=3800.0
HFT_PHASE_SOFT_MAX_FEED_LATENCY_MS=2600.0
HFT_ENTRY_MAX_SKEW_MS=2000.0

# Edge (aligned with DAY)
HFT_BUY_EDGE=4.8
HFT_NOISE_EDGE=0.9

# Ask band: allow cheap-side fills when edge is real (wider toxic-flow risk vs DAY 0.08)
HFT_ENTRY_MIN_ASK_UP=0.05
HFT_ENTRY_MIN_ASK_DOWN=0.03
HFT_ENTRY_MAX_ASK_UP=0.97
HFT_ENTRY_MAX_ASK_DOWN=0.97
HFT_MAX_ENTRY_SPREAD=0.045

# Phase router (aligned with DAY)
HFT_PHASE_SOFT_MIN_ABS_EDGE=5.2
HFT_PHASE_SOFT_MAX_ABS_SPEED=420.0
HFT_PHASE_SOFT_MAX_ABS_EDGE=18.0
HFT_PHASE_VOLATILE_MIN_ABS_SPEED=720.0
HFT_PHASE_VOLATILE_MIN_ABS_EDGE=32.0
HFT_PHASE_SOFT_MIN_TREND_AGE_SEC=1.0

# Z-score: OFF at night — CEX speed is pinned to 0 so z monotonicity blocks many latency signals
HFT_ENTRY_ZSCORE_TREND_ENABLED=0
HFT_ENTRY_ZSCORE_STRICT_TICKS=1

# Low speed (aligned with DAY)
HFT_ENTRY_LOW_SPEED_EDGE_MULT=2.2
HFT_ENTRY_LOW_SPEED_ABS=1.2

# SL/TP / hold / cooldown (aligned with DAY)
HFT_POLY_SL_MOVE=0.0150
HFT_POLY_TP_MOVE=0.0050
HFT_MIN_HOLD_SEC=3.8
LOSS_COOLDOWN_SEC=5

# Regime (aligned with DAY)
HFT_GOOD_REGIME_WINRATE=0.40
HFT_BAD_REGIME_WINRATE=0.33
HFT_RECENT_TRADES_FOR_REGIME=8
HFT_REGIME_COOLDOWN_SEC=45

# Drawdown gate (aligned with DAY)
MAX_DRAWDOWN_PCT=0.20

# Price to beat (aligned with DAY; legacy HFT_ANCHOR_* still honored)
HFT_PRICE_TO_BEAT_COUNTER_MIN_DELTA_PCT=0.0005

# Reaction score (aligned with DAY)
HFT_REACTION_MA_PERIOD=21
HFT_REACTION_MACD_FAST=12
HFT_REACTION_MACD_SLOW=26
HFT_REACTION_MACD_SIGNAL=9
HFT_REACTION_MA_REL_SCALE=0.0006
HFT_REACTION_MACD_HIST_SCALE=15.0
HFT_REACTION_W_RSI=0.45
HFT_REACTION_W_MA=0.30
HFT_REACTION_W_MACD=0.25

# RSI entry + exit bands (aligned with DAY — same hold/exit behaviour as day sim)
HFT_RSI_UP_ENTRY_MAX=57.0
HFT_RSI_UP_SLOPE_MIN=0.12
HFT_RSI_DOWN_ENTRY_MIN=47.0
HFT_RSI_DOWN_SLOPE_MAX=-0.25
HFT_ENTRY_RSI_SLOPE_FILTER_ENABLED=1
HFT_RSI_EXIT_UPPER_BASE=90
HFT_RSI_EXIT_LOWER_BASE=10
HFT_RSI_RANGE_EXIT_BAND_MARGIN=20.0
HFT_RSI_RANGE_EXIT_FADE_BUFFER=8.0
HFT_RSI_RANGE_EXIT_MIN_HOLD_SEC=2.0

# ADX: short impulse vs Polymarket lag — ~60 ticks ≈ 12–15s at ~4–5 ticks/s (see HFT_ADX_TICK_LEN).
# Larger (120–200) = smoother, slower; smaller (40–60) = faster reaction, noisier.
HFT_ADX_PERIOD=14
HFT_ADX_TICK_LEN=60
